generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model api_keys {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String    @db.VarChar(100)
  key          String    @unique(map: "api_keys_key_unique") @db.VarChar(128)
  is_active    Boolean   @default(true)
  last_used_at DateTime? @db.Timestamp(6)
  created_by   String?   @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  users        users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "api_keys_created_by_users_id_fk")
}

model audit_log {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id    String?  @db.Uuid
  action      String   @db.VarChar(100)
  entity_type String   @db.VarChar(50)
  entity_id   String?
  payload     Json?
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  users       users?   @relation(fields: [actor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "audit_log_actor_id_users_id_fk")
}

model cranes {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String               @db.VarChar(255)
  type               crane_type           @default(travelift)
  max_pool_width     Decimal?             @db.Decimal(6, 2)
  location           String?              @db.VarChar(255)
  crane_status       crane_status         @default(active)
  description        String?
  notes              String?
  created_at         DateTime             @default(now()) @db.Timestamp(6)
  updated_at         DateTime             @default(now()) @db.Timestamp(6)
  max_capacity_kn    Int
  maintenance_blocks maintenance_blocks[]
  reservations       reservations[]
  waiting_list       waiting_list[]
}

model email_verification_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique(map: "email_verification_tokens_token_unique") @db.VarChar(255)
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "email_verification_tokens_user_id_users_id_fk")
}

model holidays {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime @db.Date
  name         String   @db.VarChar(255)
  is_recurring Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamp(6)
}

model maintenance_blocks {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  crane_id   String   @db.Uuid
  start_at   DateTime @db.Timestamp(6)
  end_at     DateTime @db.Timestamp(6)
  reason     String?
  created_by String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp(6)
  cranes     cranes   @relation(fields: [crane_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "maintenance_blocks_crane_id_cranes_id_fk")
  users      users?   @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "maintenance_blocks_created_by_users_id_fk")
}

model messages {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservation_id String       @db.Uuid
  sender_id      String       @db.Uuid
  body           String
  is_read        Boolean      @default(false)
  created_at     DateTime     @default(now()) @db.Timestamp(6)
  reservations   reservations @relation(fields: [reservation_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "messages_reservation_id_reservations_id_fk")
  users          users        @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "messages_sender_id_users_id_fk")
}

model password_resets {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique(map: "password_resets_token_unique") @db.VarChar(255)
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "password_resets_user_id_users_id_fk")
}

model reservations {
  id                                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservation_number                    String?            @unique(map: "reservations_reservation_number_unique") @db.VarChar(20)
  user_id                               String             @db.Uuid
  vessel_id                             String?            @db.Uuid
  service_type_id                       String?            @db.Uuid
  crane_id                              String?            @db.Uuid
  requested_date                        DateTime?          @db.Date
  requested_time_slot                   String?            @db.VarChar(50)
  scheduled_start                       DateTime?          @db.Timestamp(6)
  scheduled_end                         DateTime?          @db.Timestamp(6)
  duration_min                          Int                @default(60)
  status                                reservation_status @default(pending)
  vessel_name                           String?            @db.VarChar(255)
  vessel_type                           vessel_type?
  vessel_length_m                       Decimal?           @db.Decimal(7, 2)
  vessel_beam_m                         Decimal?           @db.Decimal(6, 2)
  vessel_draft_m                        Decimal?           @db.Decimal(5, 2)
  user_note                             String?
  admin_note                            String?
  rejection_reason                      String?
  cancel_reason                         String?
  cancelled_by_type                     String?            @db.VarChar(20)
  approved_by                           String?            @db.Uuid
  approved_at                           DateTime?          @db.Timestamp(6)
  completed_at                          DateTime?          @db.Timestamp(6)
  is_maintenance                        Boolean            @default(false)
  reminder_sent                         Boolean            @default(false)
  contact_phone                         String?            @db.VarChar(50)
  lift_purpose                          String?
  created_at                            DateTime           @default(now()) @db.Timestamp(6)
  updated_at                            DateTime           @default(now()) @db.Timestamp(6)
  vessel_registration                   String?            @db.VarChar(100)
  vessel_weight_tons                    Decimal?           @db.Decimal(8, 2)
  messages                              messages[]
  users_reservations_approved_byTousers users?             @relation("reservations_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "reservations_approved_by_users_id_fk")
  cranes                                cranes?            @relation(fields: [crane_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "reservations_crane_id_cranes_id_fk")
  service_types                         service_types?     @relation(fields: [service_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "reservations_service_type_id_service_types_id_fk")
  users_reservations_user_idTousers     users              @relation("reservations_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "reservations_user_id_users_id_fk")
  vessels                               vessels?           @relation(fields: [vessel_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "reservations_vessel_id_vessels_id_fk")
}

model seasons {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(100)
  start_date    DateTime @db.Date
  end_date      DateTime @db.Date
  working_hours Json
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamp(6)
}

model service_types {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String         @db.VarChar(255)
  description          String?
  default_duration_min Int            @default(60)
  is_active            Boolean        @default(true)
  sort_order           Int            @default(0)
  created_at           DateTime       @default(now()) @db.Timestamp(6)
  updated_at           DateTime       @default(now()) @db.Timestamp(6)
  reservations         reservations[]
  waiting_list         waiting_list[]
}

model settings {
  key        String   @id @db.VarChar(100)
  value      Json
  updated_by String?  @db.Uuid
  updated_at DateTime @default(now()) @db.Timestamp(6)
  users      users?   @relation(fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "settings_updated_by_users_id_fk")
}

model users {
  id                                           String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                        String                      @unique(map: "users_email_unique") @db.VarChar(320)
  password_hash                                String?                     @db.VarChar(255)
  google_id                                    String?                     @unique(map: "users_google_id_unique") @db.VarChar(255)
  first_name                                   String?                     @db.VarChar(100)
  last_name                                    String?                     @db.VarChar(100)
  name                                         String?
  phone                                        String?                     @db.VarChar(50)
  role                                         role                        @default(user)
  user_status                                  user_status                 @default(active)
  email_verified_at                            DateTime?                   @db.Timestamp(6)
  anonymized_at                                DateTime?                   @db.Timestamp(6)
  login_method                                 String?                     @db.VarChar(64)
  created_at                                   DateTime                    @default(now()) @db.Timestamp(6)
  updated_at                                   DateTime                    @default(now()) @db.Timestamp(6)
  last_signed_in                               DateTime                    @default(now()) @db.Timestamp(6)
  must_change_password                         Boolean                     @default(false)
  api_keys                                     api_keys[]
  audit_log                                    audit_log[]
  email_verification_tokens                    email_verification_tokens[]
  maintenance_blocks                           maintenance_blocks[]
  messages                                     messages[]
  password_resets                              password_resets[]
  reservations_reservations_approved_byTousers reservations[]              @relation("reservations_approved_byTousers")
  reservations_reservations_user_idTousers     reservations[]              @relation("reservations_user_idTousers")
  settings                                     settings[]
  vessels                                      vessels[]
  waiting_list                                 waiting_list[]
}

model vessels {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id     String         @db.Uuid
  name         String         @db.VarChar(255)
  type         vessel_type
  length_m     Decimal?       @db.Decimal(7, 2)
  beam_m       Decimal?       @db.Decimal(6, 2)
  draft_m      Decimal?       @db.Decimal(5, 2)
  registration String?        @db.VarChar(100)
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  updated_at   DateTime       @default(now()) @db.Timestamp(6)
  weight_tons  Decimal?       @db.Decimal(8, 2)
  reservations reservations[]
  users        users          @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "vessels_owner_id_users_id_fk")
  waiting_list waiting_list[]
}

model waiting_list {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String              @db.Uuid
  vessel_id       String?             @db.Uuid
  service_type_id String?             @db.Uuid
  crane_id        String?             @db.Uuid
  requested_date  DateTime            @db.Date
  position        Int                 @default(0)
  status          waiting_list_status @default(waiting)
  vessel_data     Json?
  notified        Boolean             @default(false)
  expires_at      DateTime?           @db.Timestamp(6)
  created_at      DateTime            @default(now()) @db.Timestamp(6)
  updated_at      DateTime            @default(now()) @db.Timestamp(6)
  cranes          cranes?             @relation(fields: [crane_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "waiting_list_crane_id_cranes_id_fk")
  service_types   service_types?      @relation(fields: [service_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "waiting_list_service_type_id_service_types_id_fk")
  users           users               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "waiting_list_user_id_users_id_fk")
  vessels         vessels?            @relation(fields: [vessel_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "waiting_list_vessel_id_vessels_id_fk")
}

enum crane_status {
  active
  inactive
  maintenance
}

enum crane_type {
  travelift
  portalna
  mobilna
  ostalo
}

enum reservation_status {
  pending
  approved
  rejected
  cancelled
  completed
  waitlisted
}

enum role {
  user
  operator
  admin
}

enum user_status {
  active
  suspended
  pending_verification
}

enum vessel_type {
  jedrilica
  motorni
  katamaran
  ostalo
}

enum waiting_list_status {
  waiting
  notified
  accepted
  expired
  cancelled
}
